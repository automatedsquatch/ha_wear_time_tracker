# =============================================================================
# Wear Time Tracker - Configuration Variables
# =============================================================================
# Fill in these values with your own Home Assistant entities, then run:
#   ./install.sh
#
# The install script reads this file and produces ready-to-deploy HA files
# in the output/ directory with your entities substituted in.
# =============================================================================

# --- NOTIFICATION SERVICE ----------------------------------------------------
# The Home Assistant service used to send push/message notifications.
#
# Common values:
#   notify.notify                      - Default HA notification group
#   notify.mobile_app_<your_phone>     - Companion app on a specific device
#   notify.pushover                    - Pushover integration
#
# If you use Telegram, set this to telegram_bot.send_message and see the
# README for additional fields you'll need to add (target, parse_mode).
NOTIFY_SERVICE=notify.notify

# --- TTS SERVICE -------------------------------------------------------------
# The text-to-speech service for spoken reminders when you're home.
#
# Common values:
#   tts.google_translate_say     - Google Translate TTS (free, built-in)
#   tts.cloud_say                - Nabu Casa Cloud TTS
#   tts.piper                    - Local Piper TTS (via Wyoming)
#   tts.amazon_polly             - AWS Polly
#
# The automation calls this service with entity_id and message parameters.
# If your TTS service uses a different call format, you may need to adjust
# the automation actions after install.
TTS_SERVICE=tts.google_translate_say

# --- DEFAULT SPEAKER ---------------------------------------------------------
# The media_player entity to use for TTS announcements.
#
# Examples:
#   media_player.living_room_speaker
#   media_player.kitchen_display
#   media_player.bedroom_echo
#
# TIP: This package routes all TTS to a single speaker. If you have room-level
# presence detection (e.g., Bermuda BLE tracking, ESPresense, or phone-based
# area sensors), you can extend the automations to pick a speaker dynamically
# based on which room you're in. See the README for a template you can drop in.
DEFAULT_SPEAKER=media_player.living_room_speaker

# --- PRESENCE SENSOR ---------------------------------------------------------
# A binary_sensor that is 'on' when you're home. TTS announcements only play
# when this sensor is 'on' (push notifications always fire regardless).
#
# Common values:
#   binary_sensor.person_is_home       - A person entity's home/away state
#   person.your_name                   - HA person entity (state = 'home')
#   binary_sensor.anyone_home          - Group/bayesian sensor
#
# If you don't have or want presence-based TTS filtering, create a helper
# toggle (input_boolean) and leave it on, or set this to any entity that
# is always 'on'.
PRESENCE_SENSOR=binary_sensor.person_is_home

# --- DEVICE NAME -------------------------------------------------------------
# The display name used in notification messages and alert titles.
# Only affects user-visible text, NOT entity IDs (those always use "liners_").
#
# Examples:
#   liners          - Orthodontic liners
#   retainers       - Dental retainers
#   aligners        - Clear aligners (Invisalign, etc.)
#   trays           - Whitening trays
#   guard           - Night guard / bite guard
#   compression     - Compression garment
DEVICE_NAME=aligners
